# Required: Absolute path to your Knowledge Hub folder in WSL/Linux format
KNOWLEDGE_HUB_PATH=/path/to/your/knowledge-hub

# Required: Your host User ID and Group ID to prevent permission issues (run 'id -u' and 'id -g')
USER_ID=1000
GROUP_ID=1000

# Optional: Enable the HTTP Ingest API
ENABLE_INGEST_API=true
PORT=3000
LIBRARIAN_API_KEY=librarian-secret-key
